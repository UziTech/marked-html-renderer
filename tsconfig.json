{
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "noEmit": true,
    "rootDir": "./src",
    "sourceMap": false,
    "strict": true,
    "target": "es2023",
    "verbatimModuleSyntax": true,
  },
  "include": [
    "./src/*.ts",
  ],
}
